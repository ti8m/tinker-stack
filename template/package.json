{
  "name": "planning-stack-template",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "build:data": "turbo run build:data",
    "build:msw": "turbo build --filter=@repo/msw",
    "build:prototype": "turbo build --filter=@repo/prototype",
    "dev": "turbo run dev",
    "docs": "turbo run docs",
    "lint": "turbo run lint -- --fix",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "upgrade": "npx npm-check-updates --interactive --format group -c 2",
    "clean": "rimraf .turbo && turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "@repo/api": "*",
    "eslint-plugin-import": "^2.32.0",
    "prettier": "^3.9.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "turbo": "^2.10.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22"
  },
  "resolutions": {
  },
  "overrides": {
    "zod": "^4.4.3",
    "zod-validation-error": "^4.0.2",
    "eslint-plugin-react-compiler": {
      "zod": "^3.25.0",
      "zod-validation-error": "3.5.3"
    }
  },
  "type": "module",
  "packageManager": "npm@11.18.0",
  "license": "MIT",
  "workspaces": [
    "api",
    "config/eslint",
    "config/typescript",
    "docs",
    "frontend",
    "mocks",
    "msw",
    "prototype",
    "ui"
  ],
  "dependencies": {}
}