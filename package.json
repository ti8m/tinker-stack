{
  "name": "create-tinker-stack",
  "version": "0.2.13",
  "bin": {
    "create-tinker-stack": "create/index.js"
  },
  "type": "module",
  "files": [
    "template",
    "example-templates",
    "create",
    "!**/node_modules/**",
    "!**/dist/**",
    "!**/build/**",
    "!**/.turbo/**",
    "!**/.react-router/**",
    "!**/coverage/**",
    "!**/data-mocks/**",
    "!**/.cache/**",
    "!**/*.tsbuildinfo",
    "!**/package-lock.json"
  ],
  "engines": {
    "node": ">=22.3.0"
  },
  "repository": {
    "url": "https://github.com/ti8m/tinker-stack"
  },
  "keywords": [
    "tinker-stack",
    "react",
    "monorepo",
    "starter",
    "template",
    "typescript",
    "turborepo",
    "prototype",
    "prototyping",
    "msw",
    "faker",
    "frontend",
    "scaffold",
    "create-tinker-stack"
  ],
  "scripts": {
    "clean:template": "find template example-templates -type d \\( -name node_modules -o -name dist -o -name build -o -name .turbo -o -name .react-router -o -name coverage -o -name data-mocks -o -name .cache \\) -prune -exec rm -rf {} + && find template example-templates -type f \\( -name package-lock.json -o -name '*.tsbuildinfo' \\) -delete",
    "prerelease": "npm run clean:template",
    "release": "commit-and-tag-version",
    "test": "npm run test:e2e",
    "test:e2e": "vitest run --no-file-parallelism",
    "upgrade:template": "npx npm-check-updates --interactive --format group -c 2 -w --cwd template",
    "postupgrade:template": "find template example-templates -name package-lock.json -delete && find template example-templates -name node_modules -type d -prune -exec rm -rf {} +",
    "upgrade:root": "npx npm-check-updates --interactive --format group -c 2"
  },
  "dependencies": {
    "execa": "^9.6.1",
    "inquirer": "^13.0.2"
  },
  "devDependencies": {
    "commit-and-tag-version": "^12.7.3",
    "vitest": "^4.1.9"
  }
}
